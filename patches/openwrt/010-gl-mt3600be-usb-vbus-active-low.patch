From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: yjy116 <yjy116@users.noreply.github.com>
Date: Sat, 20 Jun 2026 14:20:00 +0800
Subject: [PATCH] mediatek: gl-mt3600be: flip USB VBUS GPIO polarity

中文：实机上 USB 控制器、USB 驱动和 usb_vbus regulator 都已正常加载，
但物理 USB 口没有 5V 供电；运行时 GPIO debug 显示 GPIO14 被拉高。
因此先按板级电源开关为低有效处理，生成测试固件验证 USB VBUS。

---
 target/linux/mediatek/dts/mt7987a-glinet-gl-mt3600be.dts | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/target/linux/mediatek/dts/mt7987a-glinet-gl-mt3600be.dts b/target/linux/mediatek/dts/mt7987a-glinet-gl-mt3600be.dts
index 111111111111..222222222222 100644
--- a/target/linux/mediatek/dts/mt7987a-glinet-gl-mt3600be.dts
+++ b/target/linux/mediatek/dts/mt7987a-glinet-gl-mt3600be.dts
@@ -56,8 +56,7 @@ fan_3p3v: regulator-fan-3p3v {
 
 	usb_vbus: regulator-usb-vbus {
 		compatible = "regulator-fixed";
-		enable-active-high;
-		gpios = <&pio 14 GPIO_ACTIVE_HIGH>;
+		gpios = <&pio 14 GPIO_ACTIVE_LOW>;
 		regulator-name = "usb_vbus";
 		regulator-boot-on;
 		regulator-min-microvolt = <5000000>;
-- 
2.51.0
