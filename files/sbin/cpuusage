#!/bin/sh

# 中文：为 LuCI 系统概览提供 CPU、连接跟踪容量和流量加速状态。
# 中文：SW OFFLOAD 是 Linux flowtable 软件快路径；CT HW 是 conntrack 的 [HW_OFFLOAD] 标记；PPE-BND 是 MTK PPE 表里实际绑定的硬件流。

get_cpu_usage() {
	top -bn1 2>/dev/null | awk '
		/^CPU/ {
			for (i = 2; i <= NF; i++) {
				if ($i == "idle" && i > 1) {
					idle = $(i - 1)
					gsub(/%/, "", idle)
					printf "%d", 100 - idle
					exit
				}
			}
			if (NF >= 8) {
				idle = $8
				gsub(/%/, "", idle)
				printf "%d", 100 - idle
			}
		}
	'
}

get_conntrack_usage() {
	local current maximum

	current="$(cat /proc/sys/net/netfilter/nf_conntrack_count 2>/dev/null || true)"
	maximum="$(cat /proc/sys/net/netfilter/nf_conntrack_max 2>/dev/null || true)"

	if [ -z "${current}" ] && [ -r /proc/net/nf_conntrack ]; then
		current="$(wc -l < /proc/net/nf_conntrack 2>/dev/null || true)"
	fi

	[ -n "${current}" ] || current="0"
	[ -n "${maximum}" ] || maximum="0"

	printf '%s/%s' "${current}" "${maximum}"
}

count_conntrack_marker() {
	local marker="$1"

	[ -r /proc/net/nf_conntrack ] || {
		printf '0 0 0 0'
		return
	}

	awk -v marker="${marker}" '
		BEGIN { tcp = 0; udp = 0; other = 0; total = 0 }
		{
			if (marker == "sw") {
				if ($0 !~ /\[OFFLOAD\]/ || $0 ~ /\[HW_OFFLOAD\]/)
					next
			} else if (marker == "hw") {
				if ($0 !~ /\[HW_OFFLOAD\]/)
					next
			}

			total++
			if ($3 == "tcp")
				tcp++
			else if ($3 == "udp")
				udp++
			else
				other++
		}
		END { printf "%d %d %d %d", tcp, udp, other, total }
	' /proc/net/nf_conntrack 2>/dev/null
}

count_ppe_bnd_file() {
	awk '
		BEGIN { tcp = 0; udp = 0; other = 0; total = 0 }
		$2 != "BND" { next }
		{
			line = tolower($0)
			total++

			if (line ~ /(^|[^a-z])tcp([^a-z]|$)/ || line ~ /proto[=: ]*6([^0-9]|$)/)
				tcp++
			else if (line ~ /(^|[^a-z])udp([^a-z]|$)/ || line ~ /proto[=: ]*17([^0-9]|$)/)
				udp++
			else
				other++
		}
		END { printf "%d %d %d %d", tcp, udp, other, total }
	' "$@" 2>/dev/null
}

count_ppe_bnd_entries() {
	local counts total

	counts="$(count_ppe_bnd_file /sys/kernel/debug/ppe*/bind)"
	set -- ${counts}
	total="${4:-0}"
	if [ "${total}" != "0" ]; then
		printf '%s' "${counts}"
		return
	fi

	count_ppe_bnd_file /sys/kernel/debug/ppe*/entries
}

get_hfo_state() {
	local flow hw

	flow="$(uci -q get firewall.@defaults[0].flow_offloading 2>/dev/null)"
	hw="$(uci -q get firewall.@defaults[0].flow_offloading_hw 2>/dev/null)"

	if [ "${flow}" = "1" ] && [ "${hw}" = "1" ]; then
		if nft list ruleset 2>/dev/null | grep -q 'flags offload'; then
			printf 'on'
			return
		fi
	fi

	printf 'off'
}

format_total() {
	set -- $1
	printf '%s' "${4:-0}"
}

format_counts() {
	set -- $1
	printf 'tcp %s udp %s other %s total %s' "${1:-0}" "${2:-0}" "${3:-0}" "${4:-0}"
}

cpu="$(get_cpu_usage)"
[ -n "${cpu}" ] || cpu="0"
conntrack="$(get_conntrack_usage)"
hfo="$(get_hfo_state)"
sw_counts="$(count_conntrack_marker sw)"
ct_hw_counts="$(count_conntrack_marker hw)"
ppe_bnd_counts="$(count_ppe_bnd_entries)"

if [ "${CPUUSAGE_DETAIL:-0}" = "1" ]; then
	printf '%s%% | CT %s | HFO %s | SW %s | CT-HW %s | PPE %s' \
		"${cpu}" \
		"${conntrack}" \
		"${hfo}" \
		"$(format_counts "${sw_counts}")" \
		"$(format_counts "${ct_hw_counts}")" \
		"$(format_counts "${ppe_bnd_counts}")"
else
	printf '%s%% | CT %s | HFO %s | SW %s | CT-HW %s | PPE %s' \
		"${cpu}" \
		"${conntrack}" \
		"${hfo}" \
		"$(format_total "${sw_counts}")" \
		"$(format_total "${ct_hw_counts}")" \
		"$(format_total "${ppe_bnd_counts}")"
fi
